        \"enabled\": true,\n          \"appId\": \"cli_a93d7b008ff6dcca\",\n          \"appSecret\": \"XmzBxn0Snncsz8YK33aSNbqwhLrBeeEP\",\n          \"connectionMode\": \"websocket\",\n          \"domain\": \"feishu\",\n          \"groupPolicy\": \"open\"\n        }\n      }\n    }\n  },\n  \"gateway\": {\n    \"port\": 18789,\n    \"mode\": \"local\",\n    \"bind\": \"loopback\",\n    \"auth\": {\n      \"mode\": \"token\",\n      \"token\": \"81585a5d2f89b382aee28ac00a4f668e819dacc99ba815a1\"\n    },\n    \"tailscale\": {\n      \"mode\": \"off\",\n      \"resetOnExit\": false\n    },\n    \"nodes\": {\n      \"denyCommands\": [\n        \"camera.snap\",\n        \"camera.clip\",\n        \"screen.record\",\n        \"contacts.add\",\n        \"calendar.add\",\n        \"reminders.add\",\n        \"sms.send\"\n      ]\n    }\n  },\n  \"plugins\": {\n    \"entries\": {\n      \"feishu\": {\n        \"enabled\": true\n      }\n    },\n    \"installs\": {\n      \"feishu\": {\n        \"source\": \"npm\",\n        \"spec\": \"@openclaw/feishu\",\n        \"installPath\": \"/home/hochoy/.openclaw/extensions/feishu\",\n        \"version\": \"2026.3.13\",\n        \"resolvedName\": \"@openclaw/feishu\",\n        \"resolvedVersion\": \"2026.3.13\",\n        \"resolvedSpec\": \"@openclaw/feishu@2026.3.13\",\n        \"integrity\": \"sha512-D5vPkgGZ9lfCQnDFlGrQN6NCSUYRgYW9k7amW3qlm9zBI4Sp+alRZVqLZ4yZ2eCXHjw9RVp/L75wjJ7NBQyfEw==\",\n        \"shasum\": \"39128ff918f8d3387331818cbe3f8b24a82e4c0d\",\n        \"resolvedAt\": \"2026-03-16T14:24:27.894Z\",\n        \"installedAt\": \"2026-03-16T14:24:35.998Z\"\n      }\n    }\n  }\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":9,"aggregated":"{\n  \"meta\": {\n    \"lastTouchedVersion\": \"2026.3.13\",\n    \"lastTouchedAt\": \"2026-03-16T14:28:26.270Z\"\n  },\n  \"wizard\": {\n    \"lastRunAt\": \"2026-03-16T12:37:06.681Z\",\n    \"lastRunVersion\": \"2026.3.13\",\n    \"lastRunCommand\": \"onboard\",\n    \"l