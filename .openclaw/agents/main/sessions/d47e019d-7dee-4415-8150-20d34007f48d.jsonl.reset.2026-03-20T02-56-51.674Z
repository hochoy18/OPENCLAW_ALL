9 Mar 19 15:34 update-check.json\ndrwxr-xr-x  6 hochoy hochoy 4096 Mar 19 17:24 workspace\ndrwxr-xr-x  8 hochoy hochoy 4096 Mar 19 17:58 workspace-demo\ndrwxr-xr-x  4 hochoy hochoy 4096 Mar 19 23:27 workspace-wechat-assistant"}],"details":{"status":"completed","exitCode":0,"durationMs":40,"aggregated":"API Key: sk-kimi-Y311pdLbY8kXigdqhyjfKBjhNdzl4WRzJFderDmHC8eLPhwJMrTmSuG5e8jeaqND\nAuth Token: sk-kimi-Y311pdLbY8kXigdqhyjfKBjhNdzl4WRzJFderDmHC8eLPhwJMrTmSuG5e8jeaqND\ntotal 80\ndrwx------ 21 hochoy hochoy 4096 Mar 19 17:55 .\ndrwx------ 10 hochoy hochoy 4096 Mar 19 23:16 ..\ndrwx------  5 hochoy hochoy   54 Mar 17 22:40 agents\ndrwxr-xr-x  2 hochoy hochoy   24 Mar 16 20:45 canvas\ndrwxr-xr-x  2 hochoy hochoy   88 Mar 16 20:44 completions\ndrwx------  2 hochoy hochoy  184 Mar 19 23:46 credentials\ndrwx------  3 hochoy hochoy   56 Mar 19 08:03 cron\ndrwx------  3 hochoy hochoy   20 Mar 19 23:47 delivery-queue\ndrwxr-xr-x  2 hochoy hochoy   45 Mar 19 23:40 devices\n-rw-r--r--  1 hochoy hochoy  101 Mar 16 22:17 .env\n-rw-------  1 hochoy hochoy  178 Mar 19 23:49 exec-approvals.json\ndrwxr-xr-x  2 hochoy hochoy    6 Mar 17 09:25 extensions\ndrwxr-xr-x  3 hochoy hochoy   19 Mar 16 22:28 feishu\ndrwxr-xr-x  2 hochoy hochoy   49 Mar 17 09:39 identity\ndrwx------  2 hochoy hochoy   32 Mar 17 00:21 logs\ndrwx------  3 hochoy hochoy   21 Mar 19 11:03 media\ndrwxr-xr-x  2 hochoy hochoy   25 Mar 16 21:57 memory\n-rw-r--r--  1 hochoy hochoy 5384 Mar 19 23:44 openclaw.json\n-rw-------  1 hochoy hochoy 4676 Mar 18 14:32 openclaw.json.backup\n-rw-------  1 hochoy hochoy 4734 Mar 18 14:33 openclaw.json.bak\n-rw-------  1 hochoy hochoy 4676 Mar 18 14:33 openclaw.json.bak.1\n-rw-------  1 hochoy hochoy 4125 Mar 18 14:29 openclaw.json.bak.2\n-rw-------  1 hochoy hochoy 3248 Mar 17 22:45 openclaw.json.bak.3\n-rw-------  1 hochoy hochoy 3011 Mar 17 22:40 openclaw.json.bak.4\ndrwxr-xr-x  4 root   root     34 Mar 16 21:15 .qoder\ndrwxr-xr-x  5 hochoy hochoy   64 Mar 19 17:20 skills\ndrwx---